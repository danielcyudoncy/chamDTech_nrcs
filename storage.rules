rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profile_pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow general media access
    match /media/{allPaths=**} {
      allow read: if request.auth != null;
      // Allow write if you're an admin (this can be refined later if needed)
      // Since specific role check is tricky across services, we'll keep it simple for now
      allow write: if request.auth != null;
    }
  }
}
